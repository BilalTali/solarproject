#!/usr/bin/expect -f

set timeout 600
set host "92.249.46.36"
set port "65002"
set user "u335000182"
set pass "Sugen@9313"
set remote_path "/home/u335000182/domains/andleebsurya.in/public_html/backend"

puts "\n--- Executing Remote Commands (with --force for Production) ---\n"
spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host "cd $remote_path && composer install --no-dev --optimize-autoloader --no-interaction && php artisan migrate --force && php artisan db:seed --class=SuperAdminSeeder --force && php artisan db:seed --class=WaChatbotCategorySeeder --force && php artisan optimize:clear && echo --- COMMANDS FINISHED ---"
expect {
    "password:" {
        send "$pass\r"
        exp_continue
    }
    eof
}

puts "\n--- Remote Execution Complete ---\n"
